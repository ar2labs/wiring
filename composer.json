{
    "name": "ar2labs/wiring",
    "description": "Wiring is a PHP micro framework core with Interoperability (PSRs).",
    "type": "library",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "AR2 Labs Members",
            "email": "ar2labs@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-json": "*",
        "ext-mbstring": "*",
        "psr/cache": "^3.0",
        "psr/container": "^2.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Wiring\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wiring\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@phpunit",
            "@phpstan"
        ],
        "check-all": [
            "@composer-validate",
            "@composer-audit",
            "@platform-check",
            "@php-cs-fixer-check",
            "@phpstan",
            "@phpunit-clover"
        ],
        "composer-validate": "composer validate --strict",
        "composer-audit": "composer audit --locked --abandoned=fail",
        "platform-check": "composer check-platform-reqs",
        "php-cs-fixer": "vendor/bin/php-cs-fixer fix --config=php_cs.dist --no-interaction",
        "php-cs-fixer-check": "vendor/bin/php-cs-fixer fix --config=php_cs.dist --dry-run --diff --no-interaction",
        "phpunit": "vendor/bin/phpunit --configuration phpunit.xml.dist --coverage-html coverage --colors=always",
        "phpunit-clover": "vendor/bin/phpunit --configuration phpunit.xml.dist --coverage-clover build/logs/clover.xml --log-junit build/logs/junit.xml --colors=always",
        "phpstan": "vendor/bin/phpstan analyse --configuration phpstan.neon --no-progress --ansi"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0"
    }
}
